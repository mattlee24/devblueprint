# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: required for account deletion. Never prefix with NEXT_PUBLIC_.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI: for detailed project blueprint & task generation (optional; falls back to rule-based)
# OPENAI_API_KEY=sk-...

# Optional: for generating database types (run: supabase gen types typescript)
# SUPABASE_PROJECT_ID=your-project-ref
