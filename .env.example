# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: required for account deletion. Never prefix with NEXT_PUBLIC_.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI: for project blueprint, task, and proposal generation (optional; falls back when missing)
# Get a free API key: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-gemini-api-key
# Optional: override model if you hit rate limits (e.g. GEMINI_MODEL=gemini-1.5-flash)

# Optional: for generating database types (run: supabase gen types typescript)
# SUPABASE_PROJECT_ID=your-project-ref
